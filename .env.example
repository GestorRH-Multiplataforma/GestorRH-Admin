# PLANTILLA DE VARIABLES DE ENTORNO (PRODUCCIÓN)

# Instrucciones: Copia este archivo, renómbralo a '.env'
# y sustituye los valores por tus credenciales reales.

# 1. Credenciales del dashboard de Spring Boot Admin
# Usuario y contraseña para acceder al panel de monitorización.
# Acceso exclusivo del administrador del sistema.
ADMIN_USER=tu_usuario_admin_aqui
ADMIN_PASSWORD=tu_password_admin_aqui

# 2. Credenciales de Actuator de la API (deben coincidir con las de GestorRH-API)
# Permiten a Spring Boot Admin conectarse a los endpoints de monitorización de la API.
ACTUATOR_USER=tu_usuario_actuator_aqui
ACTUATOR_PASSWORD=tu_password_actuator_aqui